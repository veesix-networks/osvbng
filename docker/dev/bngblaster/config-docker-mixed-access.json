{
  "interfaces": {
    "access": [
      {
        "interface": "eth0",
        "type": "ipoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 500,
        "outer-vlan-max": 520,
        "inner-vlan-min": 1,
        "inner-vlan-max": 2000
      },
      {
        "interface": "eth0",
        "type": "pppoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 500,
        "outer-vlan-max": 520,
        "inner-vlan-min": 2001,
        "inner-vlan-max": 4092
      }
    ]
  },
  "dhcp": {
    "enable": true,
    "retry": 25
  },
  "dhcpv6": {
    "enable": true,
    "ia-na": true,
    "ia-pd": true,
    "rapid-commit": false,
    "access-line": true,
    "ldra": true
  },
  "ipoe": {
    "ipv6": true
  },
  "pppoe": {
    "reconnect": true,
    "discovery-timeout": 3,
    "discovery-retry": 20,
    "host-uniq": true
  },
  "ppp": {
    "authentication": {
      "timeout": 10,
      "retry": 20
    },
    "lcp": {
      "conf-request-timeout": 5,
      "conf-request-retry": 10,
      "keepalive-retry": 5,
      "start-delay": 100
    },
    "ipcp": {
      "enable": true
    },
    "ip6cp": {
      "enable": true
    }
  },
  "sessions": {
    "count": 6000,
    "max-outstanding": 1000,
    "start-rate": 500,
    "stop-rate": 800
  },
  "access-line": {
    "agent-circuit-id": "eth 0/1/2/3/{session-global}:500.{session-global}",
    "agent-remote-id": "DSLAM-{session-global}"
  }
}
