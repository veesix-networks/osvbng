{
  "interfaces": {
    "access": [
      {
        "interface": "eth0",
        "type": "ipoe",
        "vlan-mode": "N:1",
        "outer-vlan-min": 300,
        "outer-vlan-max": 300
      }
    ]
  },
  "sessions": {
    "count": 1,
    "autostart": true,
    "start-rate": 10,
    "stop-rate": 10
  },
  "dhcp": {
    "enable": true,
    "retry": 10
  },
  "dhcpv6": {
    "enable": true,
    "ia-na": true,
    "ia-pd": true,
    "rapid-commit": false,
    "ldra": true
  },
  "ipoe": {
    "ipv6": true
  },
  "access-line": {
    "agent-circuit-id": "eth 0/1/relay/{session-global}:300.{session-global}",
    "agent-remote-id": "RELAY-{session-global}"
  }
}
