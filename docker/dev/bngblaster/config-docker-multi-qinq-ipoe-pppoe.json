{
  "interfaces": {
    "access": [
      {
        "interface": "eth0",
        "type": "ipoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 100,
        "outer-vlan-max": 110,
        "inner-vlan-min": 2,
        "inner-vlan-max": 100
      },
      {
        "interface": "eth0",
        "type": "pppoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 200,
        "outer-vlan-max": 210,
        "inner-vlan-min": 2,
        "inner-vlan-max": 100
      }
    ]
  },
  "dhcp": {
    "enable": true,
    "retry": 25
  },
  "dhcpv6": {
    "enable": true,
    "ia-na": true,
    "ia-pd": true,
    "rapid-commit": false,
    "access-line": true,
    "ldra": true
  },
  "ipoe": {
    "ipv6": true
  },
  "pppoe": {
    "reconnect": true,
    "discovery-timeout": 3,
    "discovery-retry": 20,
    "host-uniq": true
  },
  "ppp": {
    "authentication": {
      "timeout": 10,
      "retry": 20
    },
    "lcp": {
      "conf-request-timeout": 5,
      "conf-request-retry": 10,
      "keepalive-retry": 5,
      "start-delay": 100
    },
    "ipcp": {
      "enable": true
    },
    "ip6cp": {
      "enable": true
    }
  },
  "sessions": {
    "count": 200,
    "max-outstanding": 100,
    "start-rate": 50,
    "stop-rate": 200
  },
  "access-line": {
    "agent-circuit-id": "eth 0/1/2/3/{session-global}:100.{session-global}",
    "agent-remote-id": "DSLAM-{session-global}"
  }
}
