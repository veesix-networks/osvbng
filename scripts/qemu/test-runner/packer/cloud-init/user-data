#cloud-config
users:
  - name: root
    lock_passwd: false

ssh_pwauth: true

disable_root: false

chpasswd:
  expire: false
  users:
    - name: root
      password: testrunner
      type: text

write_files:
  - path: /etc/ssh/sshd_config.d/99-packer.conf
    content: |
      PermitRootLogin yes
      PasswordAuthentication yes
    permissions: "0644"

runcmd:
  - systemctl restart ssh
