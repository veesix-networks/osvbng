{
  "interfaces": {
    "access": [
      {
        "interface": "eth1",
        "type": "ipoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 100,
        "outer-vlan-max": 100,
        "inner-vlan-min": 10,
        "inner-vlan-max": 10
      },
      {
        "interface": "eth1",
        "type": "ipoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 120,
        "outer-vlan-max": 120,
        "inner-vlan-min": 10,
        "inner-vlan-max": 10
      },
      {
        "interface": "eth1",
        "type": "ipoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 140,
        "outer-vlan-max": 140,
        "inner-vlan-min": 10,
        "inner-vlan-max": 10
      }
    ]
  },
  "dhcp": {
    "enable": true,
    "retry": 30
  },
  "dhcpv6": {
    "enable": true,
    "ia-na": true,
    "ia-pd": true,
    "rapid-commit": false,
    "access-line": true,
    "ldra": true
  },
  "ipoe": {
    "ipv6": true
  },
  "access-line": {
    "agent-circuit-id": "eth 0/1/{session-global}:{outer-vlan}.{inner-vlan}",
    "agent-remote-id": "DEV-{session-global}"
  },
  "sessions": {
    "count": 3,
    "max-outstanding": 3,
    "start-rate": 3,
    "stop-rate": 3
  }
}
