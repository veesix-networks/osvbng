{
  "interfaces": {
    "network": [
      {
        "interface": "eth2",
        "address": "10.0.0.2/30",
        "gateway": "10.0.0.1"
      }
    ],
    "access": [
      {
        "interface": "eth1",
        "type": "pppoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 200,
        "outer-vlan-max": 200,
        "inner-vlan-min": 1,
        "inner-vlan-max": 10
      }
    ]
  },
  "pppoe": {
    "reconnect": false,
    "discovery-timeout": 5,
    "discovery-retry": 10,
    "host-uniq": true
  },
  "ppp": {
    "authentication": {
      "username": "wholesale-ppp-username",
      "password": "wholesale-password",
      "timeout": 10,
      "retry": 10,
      "protocol": "CHAP"
    },
    "lcp": {
      "conf-request-timeout": 5,
      "conf-request-retry": 10,
      "keepalive-retry": 5
    },
    "ipcp": {
      "enable": true
    },
    "ip6cp": {
      "enable": true
    }
  },
  "access-line": {
    "agent-circuit-id": "eth 0/2/{session-global}:200.{session-global}",
    "agent-remote-id": "user{session-global}"
  },
  "l2tp-server": [
    {
      "name": "bngblaster-lns",
      "address": "10.0.0.2",
      "secret": "shared",
      "receive-window-size": 16,
      "hello-interval": 60
    }
  ],
  "sessions": {
    "count": 1,
    "max-outstanding": 1,
    "start-rate": 1,
    "stop-rate": 1
  }
}
