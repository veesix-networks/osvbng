{
  "interfaces": {
    "access": [
      {
        "interface": "eth1",
        "type": "pppoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 200,
        "outer-vlan-max": 200,
        "inner-vlan-min": 2,
        "inner-vlan-max": 70
      }
    ]
  },
  "pppoe": {
    "reconnect": false,
    "discovery-timeout": 5,
    "discovery-retry": 10,
    "host-uniq": true
  },
  "ppp": {
    "authentication": {
      "username": "user{session-global}",
      "password": "test",
      "timeout": 10,
      "retry": 10
    },
    "lcp": {
      "conf-request-timeout": 5,
      "conf-request-retry": 10,
      "keepalive-retry": 5
    },
    "ipcp": {
      "enable": true
    },
    "ip6cp": {
      "enable": true
    }
  },
  "access-line": {
    "agent-circuit-id": "eth 0/2/{session-global}:200.{session-global}",
    "agent-remote-id": "user{session-global}"
  }
}
