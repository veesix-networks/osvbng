{
  "interfaces": {
    "access": [
      {
        "interface": "eth1",
        "type": "ipoe",
        "vlan-mode": "N:1",
        "outer-vlan-min": 300,
        "outer-vlan-max": 300
      },
      {
        "interface": "eth1",
        "type": "ipoe",
        "vlan-mode": "N:1",
        "outer-vlan-min": 400,
        "outer-vlan-max": 400
      }
    ]
  },
  "sessions": {
    "count": 2,
    "autostart": true,
    "start-rate": 10,
    "stop-rate": 10
  },
  "dhcp": {
    "enable": true,
    "retry": 10
  },
  "access-line": {
    "agent-circuit-id": "eth 0/1/test/{session-global}:{outer-vlan}.{session-global}",
    "agent-remote-id": "TEST-{session-global}"
  }
}
